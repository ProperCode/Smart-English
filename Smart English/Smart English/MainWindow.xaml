<Window x:Name="Wmain" x:Class="Smart_English.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Smart_English"
        mc:Ignorable="d"
        Title="Smart English" Height="796" Width="889" FontSize="14"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize" Closing="Wmain_Closing">
    <Grid Margin="0,0,0,0">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                <GradientStop Color="White" Offset="1"/>
                <GradientStop Color="#f3f3f3"/>
            </LinearGradientBrush>
        </Grid.Background>
        <!-- Menu -->
        <Menu x:Name="Mmain" Width="Auto" Height="28" Background="#FFEAEAEA" VerticalAlignment="Top" FontSize="14" Padding="0,2,2,0">
            <MenuItem x:Name="MIplik" Header="Plik">
                <MenuItem x:Name="MIzamknij" Header="Zamknij" Click="MIzamknij_Click" Background="#FFEAEAEA" />
            </MenuItem>
            <MenuItem x:Name="MIzmien_profil" Header="Zmień profil" Click="MIzmien_profil_Click">
            </MenuItem>
            <MenuItem x:Name="MIpomoc" Header="Instrukcja" Click="MIpomoc_Click">
            </MenuItem>
            <MenuItem x:Name="MIabout" Header="O programie" Click="MIabout_Click">
            </MenuItem>
        </Menu>
        <Label Content="Bazy" HorizontalAlignment="Left" Margin="73,30,0,0" VerticalAlignment="Top" FontSize="18"/>
        <ListBox x:Name="LBbazy" Margin="10,67,685,109" SelectionChanged="LBbazy_SelectionChanged" PreviewMouseDoubleClick="LBbazy_PreviewMouseDoubleClick">
        </ListBox>
        <GroupBox x:Name="GBtryb_nauki" Header="Tryb nauki" HorizontalAlignment="Left" Width="250" Height="124" Margin="206,64,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <RadioButton x:Name="RBautomatyczny" Content="Automatyczny" HorizontalAlignment="Left" Margin="10,10,0,0" Checked="RBautomatyczny_Checked"/>
                <RadioButton x:Name="RBpolautomatyczny" Content="Półautomatyczny" HorizontalAlignment="Left" Margin="10,40,0,0" Checked="RBpolautomatyczny_Checked"/>
                <RadioButton x:Name="RBreczny" Content="Ręczny" HorizontalAlignment="Left" Margin="10,70,0,0" Checked="RBreczny_Checked"/>
            </Grid>
        </GroupBox>
        <GroupBox x:Name="GBopoznienia" Header="Opóźnienia" HorizontalAlignment="Left" Width="250" Height="137" Margin="206,193,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <TextBlock x:Name="TextBlock1" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" 
                           Text="Dodatkowe opóźnienie po pojawieniu się zdania [s]:" VerticalAlignment="Top" Height="41" Width="170"/>
                <TextBlock x:Name="TextBlock2" HorizontalAlignment="Left" Margin="10,55,0,0" TextWrapping="Wrap" 
                    Text="Opóźnienie pomiędzy nauką kolejnych zdań [s]:" VerticalAlignment="Top" Height="41" Width="170"/>
                <TextBox x:Name="TBopoznienie_po_pojawieniu" VerticalContentAlignment="Center" HorizontalAlignment="Left" 
                         Height="23" Margin="182,19,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46" TextChanged="TBopoznienie_po_pojawieniu_TextChanged" />
                <TextBox x:Name="TBopoznienie_pomiedzy" VerticalContentAlignment="Center" HorizontalAlignment="Left" 
                         Height="23" Margin="182,64,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="46" TextChanged="TBopoznienie_pomiedzy_TextChanged" />
            </Grid>
        </GroupBox>
        <GroupBox x:Name="GBsyntezator_mowy" Header="Czytanie na głos" HorizontalAlignment="Left" Width="393" Height="197" Margin="461,64,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <CheckBox x:Name="CHBczytaj_po_ang" Content="Czytaj zdanie w języku angielskim" HorizontalAlignment="Left" Margin="10,10,0,0" 
                          VerticalAlignment="Top" Checked="CHBczytaj_po_ang_Checked" Unchecked="CHBczytaj_po_ang_Unchecked"/>
                <CheckBox x:Name="CHBczytaj_po_pol" Content="Czytaj zdanie w języku polskim" HorizontalAlignment="Left" Margin="10,40,0,0" 
                          VerticalAlignment="Top" Checked="CHBczytaj_po_pol_Checked" Unchecked="CHBczytaj_po_pol_Unchecked"/>
                <Label x:Name="Lglos_ang" Content="Głos język angielski:" HorizontalAlignment="Left" Margin="6,65,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lglos_pol" Content="Głos język polski:" HorizontalAlignment="Left" Margin="6,95,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lglosnosc" Content="Głośność:" HorizontalAlignment="Left" Margin="6,125,0,0" VerticalAlignment="Top"/>
                <ComboBox x:Name="CBglos_ang" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="231" FontSize="14" Margin="140,69,0,0" SelectionChanged="CBglos_ang_SelectionChanged"/>
                <ComboBox x:Name="CBglos_pol" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="231" FontSize="14" Margin="140,99,0,0" SelectionChanged="CBglos_pol_SelectionChanged"/>
                <ComboBox x:Name="CBglosnosc" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="231" FontSize="14" Margin="140,129,0,0" SelectionChanged="CBglosnosc_SelectionChanged"/>
            </Grid>
        </GroupBox>
        <GroupBox x:Name="GBaktualizacje" Header="Aktualizacje" HorizontalAlignment="Left" Width="393" Height="64" Margin="461,266,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <CheckBox x:Name="CHBsprawdzaj_aktualizacje" Content="Sprawdzaj aktualizacje automatycznie" HorizontalAlignment="Left" Margin="10,10,0,0" 
                          VerticalAlignment="Top" Checked="CHBsprawdzaj_aktualizacje_Checked" Unchecked="CHBsprawdzaj_aktualizacje_Unchecked"/>
            </Grid>
        </GroupBox>
        <GroupBox x:Name="GBinformacje" Header="Informacje o bazie" HorizontalAlignment="Left" Width="328" Height="263" Margin="206,376,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <Label x:Name="Lnr" Content="Nr bieżącego zdania:" HorizontalAlignment="Left" Margin="5,10,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lliczba_zdan" Content="Liczba zdań:" HorizontalAlignment="Left" Margin="5,40,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lliczba_zapam" Content="Liczba zapamiętanych zdań:" HorizontalAlignment="Left" Margin="5,70,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lpozostaly_czas" Content="Pozostały czas nauki:" HorizontalAlignment="Left" Margin="5,100,0,0" VerticalAlignment="Top"/>
                <Label x:Name="Lliczba_ukonczen" Content="Liczba ukończeń bazy:" HorizontalAlignment="Left" Margin="5,130,0,0" VerticalAlignment="Top"/>
                <TextBox x:Name="TBnr_zdania" HorizontalAlignment="Left" Width="120" Height="23" Margin="185,14,0,0" TextWrapping="Wrap" IsReadOnly="True" 
                         VerticalAlignment="Top" Grid.ColumnSpan="2" Grid.Column="1"/>
                <TextBox x:Name="TBliczba_zdan" HorizontalAlignment="Left" Width="120" Height="23" Margin="185,44,0,0" TextWrapping="Wrap" IsReadOnly="True"
                         VerticalAlignment="Top" Grid.ColumnSpan="2" Grid.Column="1"/>
                <TextBox x:Name="TBliczba_zapamietanych" HorizontalAlignment="Left" Width="120" Height="23" Margin="185,74,0,0" TextWrapping="Wrap" IsReadOnly="True"
                         VerticalAlignment="Top" Grid.ColumnSpan="2" Grid.Column="1"/>
                <TextBox x:Name="TBpozostaly_czas" HorizontalAlignment="Left" Width="120" Height="22" Margin="185,104,0,0" TextWrapping="Wrap" IsReadOnly="True"
                         VerticalAlignment="Top" Grid.ColumnSpan="2" Grid.Column="1"/>
                <TextBox x:Name="TBliczba_ukonczen" HorizontalAlignment="Left" Width="120" Height="23" Margin="185,134,0,0" TextWrapping="Wrap" IsReadOnly="True"
                         VerticalAlignment="Top" Grid.Column="1" Grid.ColumnSpan="2"/>
                <Button x:Name="Bzresetuj_nr_slowka" Content="Zresetuj nr bieżącego słówka" Foreground="Black" BorderBrush="Black" 
                        FontSize="16" Click="Bzresetuj_nr_slowka_Click" Margin="9,173,11,19" Cursor="Hand">
                    <Button.Background>
                        <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
                             StartPoint="0.5,0">
                            <GradientStop Color="White"/>
                            <GradientStop Color="#FFCDCDCD" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </GroupBox>
        <GroupBox x:Name="GBstatystyki" Header="Statystyki baz" HorizontalAlignment="Left" Width="309" Height="112" Margin="539,376,0,0" VerticalAlignment="Top" Foreground="Black">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45*"/>
                    <ColumnDefinition Width="263*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="Lliczba1" Content="Liczba zapamiętanych zdań:" HorizontalAlignment="Left" Margin="4,10,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
                <Label x:Name="Lliczba2" Content="Liczba ukończeń baz:" HorizontalAlignment="Left" Margin="4,40,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
                <TextBox x:Name="TBliczba_zapamietanych_all" HorizontalAlignment="Left" Width="100" Height="23" Margin="143,14,0,0" TextWrapping="Wrap" IsReadOnly="True" 
         VerticalAlignment="Top" Grid.Column="1" />
                <TextBox x:Name="TBliczba_ukonczen_all" HorizontalAlignment="Left" Width="100" Height="23" Margin="143,44,0,0" TextWrapping="Wrap" IsReadOnly="True"
         VerticalAlignment="Top" Grid.Column="1" />
            </Grid>
        </GroupBox>
        <Button x:Name="Brozpocznij_nauke" Content="Rozpocznij naukę" Foreground="Black" BorderBrush="Black" 
        FontSize="16" Click="Brozpocznij_nauke_Click" Margin="10,661,685,42" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
             StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="Bprzywroc_ustawienia" Content="Przywróć ustawienia domyślne" Foreground="Black" BorderBrush="Black" 
FontSize="16" Click="Bprzywroc_ustawienia_Click" Margin="197,661,423,42" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
     StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="Bzresetuj_postepy" Content="Zresetuj postępy w nauce" Foreground="Black" BorderBrush="Black" 
FontSize="16" Click="Bzresetuj_postepy_Click" Margin="457,661,197,42" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
     StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <ToolBar HorizontalAlignment="Center" Height="31" Margin="0,727,0,0" VerticalAlignment="Top" Width="889" RenderTransformOrigin="0.477,0.679">
            <Grid>
                <Label x:Name="Lnazwa_profilu" Content="Nazwa profilu: " HorizontalAlignment="Left" VerticalAlignment="Center" Height="28" Margin="10,0,0,0"/>
            </Grid>
        </ToolBar>
        <GroupBox Header="Ustawienia" Margin="196,34,9,418" FontSize="18" RenderTransformOrigin="0.5,0.5">
        </GroupBox>

        <GroupBox Header="Informacje i statystyki" Margin="196,345,10,109" FontSize="18"/>
    </Grid>
</Window>