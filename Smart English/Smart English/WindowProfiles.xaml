<Window x:Class="Smart_English.WindowProfiles"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Smart_English"
        mc:Ignorable="d"
        Title="Wybierz Profil" Height="352" Width="398" FontSize="14"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize" Icon="/Smart English.png" Closing="Window_Closing">
    <Grid>
        <ListBox x:Name="LBprofile" Margin="10,10,10,60" SelectionChanged="LBprofile_SelectionChanged" FontSize="14" PreviewMouseDoubleClick="LBprofile_PreviewMouseDoubleClick">
        </ListBox>
        <Button x:Name="Bwczytaj" Content="Wczytaj" Foreground="Black" BorderBrush="Black" 
FontSize="16" Click="Bwczytaj_Click" Margin="10,261,288,8" IsEnabled="False" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
     StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="Butworz" Content="Utwórz" Foreground="Black" BorderBrush="Black" 
            FontSize="16" Click="Butworz_Click" Margin="99,261,199,8" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
                    StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="Bedytuj" Content="Edytuj" Foreground="Black" BorderBrush="Black" 
            FontSize="16" Click="Bedytuj_Click" Margin="189,261,108,8" IsEnabled="False" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
                    StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="Busun" Content="Usuń" Foreground="Black" BorderBrush="Black" 
            FontSize="16" Click="Busun_Click" Margin="280,261,18,8" IsEnabled="False" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" 
                    StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FFCDCDCD" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
    </Grid>
</Window>
